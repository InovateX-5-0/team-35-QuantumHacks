{
  "version": 2,
  "buildCommand": "npx expo export -p web && npm run dashboard:build && mv dist-dashboard dist/dashboard",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/dashboard/",
      "permanent": true
    }
  ],
  "cleanUrls": true,
  "rewrites": [
    { "source": "/dashboard/(.*)", "destination": "/dashboard/index.html" },
    { "source": "/dashboard", "destination": "/dashboard/index.html" },
    { "source": "/(?!dashboard)(.*)", "destination": "/index.html" }
  ]
}
