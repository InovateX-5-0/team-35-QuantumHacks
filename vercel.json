{
  "version": 2,
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/dashboard/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/dashboard/(.*)",
      "destination": "/dashboard/index.html"
    },
    {
      "source": "/((?!dashboard).*)",
      "destination": "/index.html"
    }
  ]
}
